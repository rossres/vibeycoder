NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-side only — for embedded Claude chat
ANTHROPIC_API_KEY=

# Server-side only — Firebase Admin SDK for token verification
# Paste the full JSON of your Firebase service account key (single line)
FIREBASE_SERVICE_ACCOUNT_KEY=

# Server-side only — for email notifications
RESEND_API_KEY=

# Server-side only — comma-separated allowed origins for /api/chat (e.g. "https://vibeycoder.ai,https://www.vibeycoder.ai")
# Leave unset in dev to skip the origin check.
ALLOWED_ORIGINS=

# Server-side only — set to "true" once existing users have verified emails to enforce verification on /api/chat and /api/notify-week-complete
REQUIRE_EMAIL_VERIFIED=
